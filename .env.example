# Copy to `.env` and fill in values.

JWT_SECRET=change_me_in_production

# SMTP (password reset emails via nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=Service Marketplace

# Full URL of the website reset page (no trailing query). Link becomes: BASE?token=...
PASSWORD_RESET_WEB_URL=https://www.elizble.com/reset-password
PASSWORD_RESET_EXPIRE_HOURS=1
